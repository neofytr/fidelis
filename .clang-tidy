---
# Strict-but-practical lint set for a modern C++20/23 audio engine.
# Notes:
#   - bugprone-easily-swappable-parameters: too noisy on idiomatic engine APIs.
#   - readability-identifier-length: project uses short names by convention.
#   - modernize-use-trailing-return-type: aesthetic; project does not adopt it.
#   - fuchsia / google / llvm full sets are off; cherry-picked rules only.
Checks: >
  -*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  cert-*,
  -cert-err58-cpp,
  clang-analyzer-*,
  concurrency-*,
  cppcoreguidelines-*,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-type-vararg,
  hicpp-*,
  -hicpp-no-array-decay,
  -hicpp-vararg,
  misc-*,
  -misc-non-private-member-variables-in-classes,
  -misc-no-recursion,
  modernize-*,
  -modernize-use-trailing-return-type,
  performance-*,
  portability-*,
  readability-*,
  -readability-identifier-length,
  -readability-magic-numbers,

WarningsAsErrors: ''

HeaderFilterRegex: '.*\/(src|include)\/.*\.(hpp|h)$'

FormatStyle: file

CheckOptions:
  - key: readability-function-cognitive-complexity.Threshold
    value: '30'
  - key: cppcoreguidelines-avoid-do-while.IgnoreMacros
    value: 'true'
  - key: misc-include-cleaner.IgnoreHeaders
    value: ''
